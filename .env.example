# Copy to .env and adjust. docker-compose reads these values.
API_KEY=dev-local-key-change-me

# ---------------------------------------------------------------------------
# Vector database backend:  auto | pinecone | redis | memory
#   auto   -> Pinecone when PINECONE_API_KEY is set, otherwise Redis
#   memory -> in-process, non-persistent (no external service; quick demo/tests)
# ---------------------------------------------------------------------------
VECTOR_BACKEND=auto

# --- Pinecone (managed, serverless — recommended for a hosted deployment) ---
# Get a free key at https://app.pinecone.io  (the index is auto-created on boot)
 PINECONE_API_KEY=pc-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
 PINECONE_INDEX_NAME=facesentinel-kyc
 PINECONE_CLOUD=aws
 PINECONE_REGION=us-east-1
 PINECONE_NAMESPACE=kyc

# ---------------------------------------------------------------------------
# Face-embedding backend
# ONNX models are in models/
# ---------------------------------------------------------------------------
EMBEDDING_MODE=auto

# Fraud-decision thresholds (rescaled [0,1] similarity space)
# T_CANDIDATE=0.50
# T_REVIEW=0.60
# T_MATCH=0.65
